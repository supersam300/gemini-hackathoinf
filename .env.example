# ─── API Configuration ────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ─── Logging ───────────────────────────────────────────────
# Options: debug, info, warn, error
VITE_LOG_LEVEL=debug

# ─── Features ──────────────────────────────────────────────
VITE_ENABLE_SIMULATION=true
VITE_ENABLE_EXPORT=true
VITE_ENABLE_IMPORT=true

# ─── MongoDB Atlas ─────────────────────────────────────────
# Create a cluster at https://cloud.mongodb.com and paste your connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/simulide?retryWrites=true&w=majority

# ─── Local AI Agent (Ollama + Gemma 3) ────────────────────
# Start Ollama locally: `ollama serve`
# Pull model once: `ollama pull gemma3:latest`
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:latest
# Optional canary model rollout (0-100)
OLLAMA_MODEL_CANDIDATE=
OLLAMA_CANARY_PERCENT=0
# Prompt policy variants: default | strict-json-v2
AI_PROMPT_POLICY=default
# Telemetry raw capture flags (keep false in prod unless needed)
AI_TELEMETRY_STORE_RAW_PROMPT=false
AI_TELEMETRY_STORE_RAW_CANVAS=false
AI_TELEMETRY_STORE_RAW_TEXT=false
AI_TELEMETRY_STORE_RAW_ACTIONS=false

# ─── Arduino CLI ────────────────────────────────────────────
# Optional absolute path override for arduino-cli binary
# Linux/macOS example: /usr/bin/arduino-cli
# Windows example: C:\Program Files\Arduino CLI\arduino-cli.exe
ARDUINO_CLI_PATH=/usr/bin/arduino-cli

# Optional Python binary override used to run server/services/agent.py
# Linux/macOS example: /usr/bin/python3
# Windows example: C:\Users\<you>\AppData\Local\Programs\Python\Python313\python.exe
PYTHON_EXECUTABLE=
