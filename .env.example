# ─── API Configuration ────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ─── Logging ───────────────────────────────────────────────
# Options: debug, info, warn, error
VITE_LOG_LEVEL=debug

# ─── Features ──────────────────────────────────────────────
VITE_ENABLE_SIMULATION=true
VITE_ENABLE_EXPORT=true
VITE_ENABLE_IMPORT=true

# ─── MongoDB Atlas ─────────────────────────────────────────
# Create a cluster at https://cloud.mongodb.com and paste your connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/simulide?retryWrites=true&w=majority
